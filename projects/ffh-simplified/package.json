{
  "name": "ffh-simplified",
  "version": "0.1.0",
  "description": "A simplified Fall From Heaven-style 4X strategy game",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "generate-sprites": "python3 tools/generate_sprites.py",
    "cli": "npx tsx src/cli.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
